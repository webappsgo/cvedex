# cvedex devel image — same as production but binary runs in debug mode.
# Tagged :devel. For local development and debugging only.
FROM casjaysdev/go:latest AS builder

RUN apk add --no-cache git bash

ARG TARGETARCH
ARG VERSION=dev
ARG BUILD_DATE
ARG COMMIT_ID

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-s -w \
      -X 'main.Version=${VERSION}' \
      -X 'main.CommitID=${COMMIT_ID}' \
      -X 'main.BuildDate=${BUILD_DATE}'" \
    -o /app/binary/cvedex ./src

FROM alpine:latest

RUN apk add --no-cache \
    git \
    curl \
    bash \
    tini \
    tor

COPY --from=builder /app/binary/cvedex /usr/local/bin/cvedex
COPY docker/rootfs/ /
RUN chmod 755 /usr/local/bin/*

ENV MODE=development \
    DEBUG=true \
    TZ=America/New_York \
    DATABASE_DIR=/data/db/sqlite

EXPOSE 80

STOPSIGNAL SIGRTMIN+3

HEALTHCHECK --start-period=5m --interval=1m --timeout=15s --retries=3 \
    CMD /usr/local/bin/cvedex --status || exit 1

ENTRYPOINT [ "tini", "-p", "SIGTERM", "--", "/usr/local/bin/entrypoint.sh" ]
